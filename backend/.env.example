# Marketly backend environment

# Optional Redis cache. If unset or unavailable, the backend still runs.
REDIS_URL=

# Financial providers. /financials and /score need at least one usable provider.
FINNHUB_API_KEY=
FMP_API_KEY=
FMPSDK_API_KEY=
RAPIDAPI_KEY=

# Macro data for /economics and /score.
FRED_API_KEY=

# OpenAI analysis and scenario generation.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano-2025-08-07

# Future Supabase integration.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
